{
  "mcpServers": {
    "@21st-dev/magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "${TWENTYFIRST_DEV_API_KEY}"
      }
    },
    "huggingface": {
      "type": "sse",
      "url": "https://huggingface.co/mcp?login"
    },
    "motion": {
      "command": "npx",
      "args": ["-y", "https://api.motion.dev/registry.tgz?package=motion-studio-mcp&version=latest"]
    }
  }
}
